# Escolha a fonte de dados:
# mock -> usa dados locais simulados
# supabase -> usa dados via API REST do Supabase
DATA_PROVIDER=mock

SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=COLE_AQUI_A_SUA_ANON_KEY
SUPABASE_SCHEMA=public

# Opcional: nomes de tabela customizados
SUPABASE_TABLE_CONSUMO=consumo_diario
SUPABASE_TABLE_EVENTOS=eventos_escola
SUPABASE_TABLE_QUALIDADE_AR=qualidade_ar
